# Copy to .env and fill in real values for local development.
# .env is gitignored; .env.example is committed.

# Postgres -- use the local docker-compose Postgres for dev
DATABASE_URL=postgres://controlroom:devpass@localhost:5432/controlroom

# Redis -- use the local docker-compose Redis for dev (DB 12)
REDIS_URL=redis://localhost:6379/12

# Port the server listens on
PORT=3012

# Environment label: development | test | production
NODE_ENV=development

# Fine-grained GitHub PAT with read-only access on pritika292/* repos.
# Required in production; placeholder is rejected at boot.
# Scopes needed: Contents, Metadata, Issues, Pull Requests, Actions (read)
GITHUB_PAT=github_pat_replace_me_with_real_token

# HMAC secret for verifying GitHub webhook payloads.
# Generated by bootstrap-vm.sh on the VM with: openssl rand -hex 32
# Required in production; placeholder is rejected at boot.
GITHUB_WEBHOOK_SECRET=replace-me-generate-with-openssl-rand-hex-32

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info
