{
  "name": "controlroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite -c build/vite.config.ts",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "vite build -c build/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "migrate": "tsx src/server/db/migrate.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run -c build/vitest.config.ts",
    "test:watch": "vitest -c build/vitest.config.ts"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "dependencies": {
    "@azure/arm-monitor": "^7.0.0",
    "@azure/identity": "^4.13.1",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.14.0",
    "marked": "^18.0.4",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.4"
  }
}
